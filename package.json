{
  "name": "shebang-snippets",
  "displayName": "Shebang Snippets",
  "description": "Snippets for shebang lines for different types of scripts.",
  "version": "1.0.0",
  "publisher": "rpinski",
  "author": "Andreas Weizel",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rpinski/vscode-shebang-snippets"
  },
  "icon": "images/shebang-logo.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "Snippet",
    "Script",
    "Shebang",
    "Comment",
    "Shell",
    "Bash",
    "Lua",
    "Ruby",
    "Python",
    "F#",
    "FSharp",
    "Perl",
    "JS",
    "JavaScript"
  ],
  "engines": {
    "vscode": "^1.86.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "pnpm package",
    "compile": "webpack --mode development",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:vsix": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm compile-tests && pnpm compile && pnpm lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "22.0.0",
    "@types/vscode": "1.86.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.1",
    "eslint": "10.3.0",
    "mocha": "11.7.5",
    "ovsx": "0.10.9",
    "ts-loader": "9.5.4",
    "typescript": "6.0.3",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
