{
  "name": "shebang-snippets",
  "displayName": "Shebang Snippets",
  "description": "Snippets for shebang lines for different types of scripts.",
  "version": "1.0.0",
  "publisher": "rpinski",
  "author": "Andreas Weizel",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rpinski/vscode-shebang-snippets"
  },
  "icon": "images/shebang-logo.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "Snippet",
    "Script",
    "Shebang",
    "Comment",
    "Shell",
    "Bash",
    "Lua",
    "Ruby",
    "Python",
    "F#",
    "FSharp",
    "Perl",
    "JS",
    "JavaScript"
  ],
  "engines": {
    "vscode": "^1.86.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm package",
    "compile": "webpack --mode development",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:vsix": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm compile-tests && pnpm compile && pnpm lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.20",
    "@types/vscode": "1.86.0",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vscode/test-cli": "0.0.15",
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "eslint": "10.5.0",
    "mocha": "11.7.6",
    "ovsx": "1.0.1",
    "ts-loader": "9.6.0",
    "typescript": "6.0.3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "contributes": {
    "commands": []
  }
}
