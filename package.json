{
  "name": "shebang-snippets",
  "displayName": "Shebang Snippets",
  "description": "Snippets for shebang lines for different types of scripts.",
  "version": "1.0.0",
  "publisher": "rpinski",
  "author": "Andreas Weizel",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rpinski/vscode-shebang-snippets"
  },
  "icon": "images/shebang-logo.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "Snippet",
    "Script",
    "Shebang",
    "Comment",
    "Shell",
    "Bash",
    "Lua",
    "Ruby",
    "Python",
    "F#",
    "FSharp",
    "Perl",
    "JS",
    "JavaScript"
  ],
  "engines": {
    "vscode": "^1.86.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Shebang Snippets Extension",
      "type": "object",
      "properties": {
        "shebang-snippets.customShebangExecPaths": {
          "type": "object",
          "default": {},
          "description": "Allows to define sets of custom executable paths to be suggested in shebang snippets for different languages.",
          "properties": {
            "plaintext": {
              "description": "Custom executable paths for plain text files",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "shellscript": {
              "description": "Custom executable paths for shell scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "fsharp": {
              "description": "Custom executable paths for F# files",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "groovy": {
              "description": "Custom executable paths for Groovy scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "javascript": {
              "description": "Custom executable paths for JavaScript files",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "lua": {
              "description": "Custom executable paths for Lua scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "perl": {
              "description": "Custom executable paths for Perl scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "php": {
              "description": "Custom executable paths for PHP scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "powershell": {
              "description": "Custom executable paths for PowerShell scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "python": {
              "description": "Custom executable paths for Python scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "ruby": {
              "description": "Custom executable paths for Ruby scripts",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "typescript": {
              "description": "Custom executable paths for TypeScript files",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm package",
    "compile": "webpack --mode development",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:vsix": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm compile-tests && pnpm compile && pnpm lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.17",
    "@types/vscode": "1.86.0",
    "@typescript-eslint/eslint-plugin": "8.44.1",
    "@typescript-eslint/parser": "8.44.1",
    "@vscode/test-cli": "0.0.11",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.6.0",
    "ovsx": "0.10.5",
    "eslint": "9.36.0",
    "ts-loader": "9.5.4",
    "typescript": "5.9.2",
    "webpack": "5.101.3",
    "webpack-cli": "6.0.1"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}